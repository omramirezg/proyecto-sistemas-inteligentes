# ====== GOOGLE CLOUD ======
GOOGLE_CLOUD_PROJECT=tu-proyecto-id
GOOGLE_APPLICATION_CREDENTIALS=./credenciales.json
GEMINI_AUDIO_MODEL=gemini-2.5-flash

# ====== GOOGLE CLOUD STORAGE ======
GCS_BUCKET=tu-bucket-name

# ====== GOOGLE CLOUD PUB/SUB ======
PUBSUB_TOPIC=telemetria-planta-001
PUBSUB_SUBSCRIPTION=telemetria-worker
# Poner en 1 para usar Pub/Sub en lugar del loop de polling
PUBSUB_HABILITADO=0

# ====== MODELO LOCAL DE RESPALDO (GEMMA / OLLAMA) ======
# Circuit breaker: si Gemini falla 3 veces seguidas, usa Gemma local
# Requiere: ollama pull gemma3:2b && ollama serve
GEMMA_FALLBACK_HABILITADO=0
GEMMA_LOCAL_MODEL=gemma3:2b
GEMMA_OLLAMA_URL=http://localhost:11434

# ====== SHADOW MODE / A/B TESTING ======
# off     → sistema normal (sin overhead)
# shadow  → variante B corre en paralelo pero en silencio (solo log)
# ab      → SHADOW_PORCENTAJE_B % del tráfico va a la variante B
SHADOW_MODE=off
SHADOW_MODELO_B=gemini-2.0-flash-lite
SHADOW_TEMPERATURA_B=0.1
SHADOW_MAX_TOKENS_B=600
SHADOW_TOP_P_B=0.9
SHADOW_PORCENTAJE_B=20
# Dejar vacío para reusar el system prompt de A
SHADOW_SYSTEM_PROMPT_B=

# ====== TELEGRAM ======
TELEGRAM_BOT_TOKEN=tu-token-de-botfather

# ====== CORREO SUPERVISION ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@dominio.com
SMTP_PASSWORD=tu-clave-o-app-password
SMTP_SENDER=tu-correo@dominio.com
SMTP_USE_TLS=1
SUPERVISOR_EMAILS=supervisor1@dominio.com,supervisor2@dominio.com
